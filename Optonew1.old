procedure LST12
sin1=0.00     && 05.01.2005
sin2=0.00
sin3=0.00  
select 2            && akt1
go top
if i>24
   skip 24
      else
         skip i-1
endif
select 3            && wyr33
go top
select 4            && wyr4
go top
skip i-j
select 1            &&wyr2
go top
skip i-1
do while i<m
   w1=mim           && знач сч на начало месяца
   k1=ks            && коэф счетчика
   select 4
   do case
      case i<13
         w2=ego2     && кон показания сч выработки
         sin3=10e5
      case i>12.and.i<188
         w2=ego3     && кон пок-я сч сн
         sin3=10e4
      case i>187
         w2=ego4     && кон пок-я сч трансф-ров
         sin3=10e4
   endcase
   skip
   select 2
   k2=zak1           && номер счетчика
   skip
   sin1=w2-w1        && разность
   if sin1<0
      sin1=sin1+sin3
   endif
   sin2=k1*sin1
   sum1=sum1+sin2
   do PEAK1
   select 3
   go top
   set filter to ak0=i
   lld=0
   count to lld
   if lld>0
      go top
*******  для замены более 1-го раза
     Do while .not. eof()
*******
      w1=ak2
      w2=ak3
      k1=ak1
      k2=ak5
      sin1=w2-w1
      sin2=k1*sin1
      sum1=sum1+sin2+ak4
      @ str,6 say "*"
      do PEAK1
*******  для замены более 1-го раза
      skip
     Enddo
*******
   endif
   set filter to
   i=i+1
   select 1
   skip
enddo
return
procedure REZERW
clear
@ 1,15 say "РАБОТА БЛОКОВ В РЕЖИМЕ СИНХРОННОГО КОМПЕНСАТОРА."
@ 3,15 say  "╔══════════╦══════════╦══════════╦══════════╗"
@ 4,15 say  "║  N блока ║ Э/Э нач. ║ Э/Э кон .║ Э/Э мимо ║"
@ 5,15 say  "╠══════════╬══════════╬══════════╬══════════╣"
kol=6
do while kol<18
   @ kol,15 say  "║          ║          ║          ║          ║"
   kol=kol+1
enddo
@ 18,15 say "╚══════════╩══════════╩══════════╩══════════╝"
kol=6
mini=1
maxi=12
i=1
do while .t.
   @ kol,18 get num(i) pict "999"
   @ kol,28 get nn(i) pict "999999"
   @ kol,39 get nk(i) pict "999999"
   @ kol,50 get nen(i) pict "999999"
read
l = readkey()
   @ kol,18 say num(i) pict "999"
   @ kol,28 say nn(i) pict "999999"
   @ kol,39 say nk(i) pict "999999"
   @ kol,50 say nen(i) pict "999999"
if l = 12       &&  esc
 exit
endif
if l=5.or.l=270.or.l=15    && ус.end,enter,стрелка вн.
   if i = maxi
      loop
   endif
   kol=kol+1
   i=i+1
   loop
endif
if l = 4                      &&    стрелка вв.
   if i = mini
      loop
   endif
   i=i-1
   kol=kol-1
endif
enddo
return
procedure SHAKT0
 @ 5,10 say  "╔════════════════════════╦═══════════╗"
 @ 6,10 say  "║  РЕЗЕРВНЫЙ ВОЗБУДИТЕЛЬ ║           ║"
 @ 7,10 say  "╠════════════════════════╬═══════════╣"
