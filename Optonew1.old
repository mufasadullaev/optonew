@ 17,52 get imm pict "999"
@ 17,56 get igg pict "9999"
read
l=readkey()
if l=12
*grp
exit
endif
liz1 =igg*10000+imm*100+idd         && год,месяц и день
otz=1
@ 18,26 say "Расчет по  ГРП  или  ГРС  ?"
@ 18,36 prompt " ГРП "
@ 18,46 prompt " ГРС "
menu to otz
if otz=0
return
endif
igrp=1
init=1
do while .t.
pp=0
pt=0
q=0
pd=0
