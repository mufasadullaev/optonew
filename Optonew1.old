procedure PEREKR12
clear
@ 0,1 say  "  ══════════╦══════════╦══════════╦══════════╦══════════╦══════════╦══════════╗"
@ 1,1 say  "    7 БЛОК  ║  8 БЛОК  ║  9 БЛОК  ║ 10 БЛОК  ║ 11 БЛОК  ║ 12 БЛОК  ║  ВСЕГО   ║"
@ 2,1 say  "  ══════════╬══════════╬══════════╬══════════╬══════════╬══════════╬══════════╣"
@ 23,1 say "  ══════════╩══════════╩══════════╩══════════╩══════════╩══════════╩══════════╝"
@ 24,0 say re pict ""
@ 0,0 say chr(17)
@ 2,0 say chr(17)
@ 23,0 say chr(17)
do while ! eof()
set color to gr+//b
@ kol,0 say nomer pict "99"
set color to w+//b
@ kol,3 say blok7 pict "999999.999"
@ kol,13 say "║"
@ kol,14 say blok8 pict "999999.999"
@ kol,24 say "║"
@ kol,25 say blok9 pict "999999.999"
@ kol,35 say "║"
@ kol,36 say blok10 pict "999999.999"
@ kol,46 say "║"
@ kol,47 say blok11 pict "999999.999"
@ kol,57 say "║"
@ kol,58 say blok12 pict "999999.999"
@ kol,68 say "║"
@ kol,69 say sblok pict "999999.999"
@ kol,79 say "║"
kol = kol + 1
skip
enddo
do while kol<23
@ kol,13 say "║"
@ kol,24 say "║"
@ kol,35 say "║"
@ kol,46 say "║"
@ kol,57 say "║"
@ kol,68 say "║"
@ kol,79 say "║"
kol=kol+1
enddo
return
procedure PERGET12
@ kol,3 get blok7 pict "999999.999"
@ kol,14 get blok8 pict "999999.999"
