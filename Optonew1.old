@ str,64 say bb1 pict "99999.9"
@ str,80 say bb2 pict "9999.9"
@ str,96 say bb3 pict "9999.9"
@ str,115 say bb4 pict "99.9"
@ str,124 say bb5 pict "999.99"
@ str,130 say ":"
str=str+1
return
procedure TRANS
zw1=0
trtr2=0
trtr3=0
select 1
go top
skip i-1
trtr2=trns
trtr3=trks
ks0=tr(i)*(trtr3-trtr2)*0.001
zkk1=0
if zam=2
   zkk=i+187
   select 3
   use wyrab3.dbf
   go top
   set filter to li0=zkk
   lld=0
   count to lld
   if lld>0
      go top
      zkk1=li1*(li3-li2)
      zkk1=(zkk1+li4)*0.001
      prom=trtr3
      trtr2=li2
      trtr3=li3
      repl li6 with prom
      zw1=1
   endif
   set filter to
endif
select 1
ks0=ks0+zkk1
bb1=ks0+0.05
@ str,30 say tr(i) pict "9999"
if zw1>0
   @ str,34 say "*"
endif
*@ str,37 say trtr2 pict "9999999"
@ str,36 say trtr2 pict "99999.99"
*@ str,47 say trtr3 pict "9999999"
@ str,47 say trtr3 pict "99999.99"

@ str,95 say bb1 pict "99999.9"
@ str,130 say ":"
skip
str=str+1
sum4=sum4+ks0         && всего по транс.
i=i+1
return
procedure ZAMENA
nn=0
