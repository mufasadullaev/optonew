if nomer = maxi
loop
endif
i=0
do while ! eof()
skip
i=i+1
if i = 18
exit
endif
enddo
if i<18
seek maxi
endif
nom=nomer
kol=5
do BAXEKR
seek nom
kol=5
loop
endif
if l = 4
if nomer=mini
loop
endif
skip -1
nom=nomer
if kol>5
kol = kol - 1
loop
else
kol=5
do BAXEKR
seek nom
kol=5
endif
loop
endif
