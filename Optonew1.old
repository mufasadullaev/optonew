@ 24,0 say "└─────────┴─────────┴─────────┴─────────┴─────────┴───Нажмите любую клавишу...─┘"
select 3
use pere3
go top
select 2
go top
do while ! eof()
gg=int(nomer/10000)
dd=nomer-gg*10000
mm=int(dd/100)
dd=dd-mm*100
select 3
st=strok
pz=pozic
skip
select 2
@ st,pz say dd pict "99"
if dd<10
@ st,pz say "0"
endif
@ st,pz+2 say "."
@ st,pz+3 say mm pict "99"
if mm<10
@ st,pz+3 say "0"
endif
@ st,pz+5 say "."

*@ st,pz+6 say gg pict "99"

* в связи с 2000 годом:
@ st,pz+6 say gg-int(gg/100)*100 pict "99"

if pz<71
@ st,pz+9 say "│"
endif
skip
enddo
@ 24,76 say "."
l=inkey(0)
return
