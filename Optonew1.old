   if li0 > 0
      select 2
      use wyrab2 index wyrab2
      select 4
      use wyrab33.dbf
      select 5
      use akt1.dbf
      select 3
      go top
      do while li0 > 0
         w1=li0    &&номер счетчика
         w2=li1    &&коэф. счетчика
         ks1=li2   &&начальное показ.
         ks2=li4   &&энергия мимо
         ks4=li6   && кон. показ.замененного счет.
         w4=li5    &&завод.номер счет.
         kk6=li3   &&конечное замененного
         select 2
         go top
         skip w1-1
         nom=ks
         ks3=mim
         repl ks with w2
         repl mim with ks1
         select 5            && для акта
         go top
         if w1<25
            skip w1-1
            else
               i=w1-163       && трансформаторы
               skip i-1       && изм.30.04.97
*suspe                         && замена сч.трансф
         endif
            zw0=zak1          &&старый номер
            repl zak1 with w4
         select 4
         go bott
         append blank            && замененные
         repl ak0 with w1
         repl ak1 with nom
         repl ak2 with ks3
         repl ak3 with ks4
         repl ak4 with ks2
         repl ak5 with zw0
         select 3
         repl li0 with 0
         repl li1 with 0
         repl li2 with 0
         repl li3 with 0
         repl li4 with 0
         repl li5 with 0
         repl li6 with 0
         skip
         select 1
         go top
         if w1 < 13
            skip w1-1
            repl pnw with kk6
            repl pkw with kk6
               else
                  if w1 > 12 .and. w1 < 25
                    skip w1-13
                     repl pns with kk6
                     repl pks with kk6
                  endif
           endif
         go top
*suspe
         if w1 > 24
            skip i-25
            repl trns with kk6
            repl trks with kk6
         endif
         select 3
      enddo
   endif
select 3
go top
dele all
pack
endif
