procedure SEMES
if prizn=0        && Этот признак получает значение 1 или 0 в WYMES
   return
endif
save screen to ww
   clear
@ 8,20 say "2.SEMES"
   otz=2
   @ 9,20 say "ВЫ ДЕЙСТВИТЕЛЬНО ХОТИТЕ МОДИФИЦИРОВАТЬ БАЗУ  "
   @ 10,28 say " ДЛЯ РАСЧЕТА СЕЛЕКТОРА ?!!! "
   @ 11,24 prompt " НЕТ "
   @ 11,33 prompt " ДА "
   menu to otz
      if otz=0.or.otz=1
         return
      endif
   clear
   @ 10,25 say "ИДЕТ МОДИФИЦИКАЦИЯ БАЗЫ  ДЛЯ СЕЛЕКТОРА !!! "
   @ 11,25 say "                ЖДИТЕ... "
select 1
use sel1 index sel12
select 2
use sel2 index sel2
select 3
use wyrab2 index wyrab2
select 5
use sel3 index sel3
select 7
use sel4.dbf
select 1
go top
do while ! eof()
   repl sen with sek
   skip
enddo
sele 2
go top
lld=0
count to lld
if lld > 0
   go top
   do while ! eof()
      now1=zap1      && N счет.
      now2=zap4      && кон.зн.
      now3=zap2      &&  коэф.счет.
      sele 1
      seek now1
      if .not. found()
         sele 2
         skip
         loop
      endif
      repl sen with now2
      repl sek with now2
      sele 3
      go top
      now1=now1-1
      skip now1
      repl ks with now3
      repl mim with now2
      sele 2
      dele
      pack
   enddo

endif
sele 2
go top
lld=0
count to lld
if lld>0
   go top
   do while ! eof()
      now1=zap1
      now2=zap2
      now3=zap4
      sele 3
      go top
      skip now1-1
      repl ks with now2
      repl mim with now3
      sele 5
      set filter to nsb=now1
      if .not. found()
         clear
         @ 15,25 say "ОШИБКА В ЗАМЕНЕ СЧЕТЧИКОВ 3-го ЛИСТА."
         @ 16,25 say "Нажмиите любую клавишу"
         read
         skip
         loop
         set filter to
      endif
      go top
      repl nac with now3
      repl kon with now3
      set filter to
      sele 2
      skip
   enddo
sele 2
go top
dele all
pack
endif
sele 3
go top
skip 24
sele 1
go top
do while ! eof()
   now2=sek
   sele 3
   repl mim with now2
   repl mik with now2
   skip
   sele 1
   skip
enddo
select 5
go top
do while ! eof()
   now1=nsb
   now2=kon
   repl nac with now2
   sele 3
   go top
   skip now1-1
   repl mim with now2
   repl mik with now2
   sele 5
   skip
enddo
select 4
use wyrab33.dbf
go top
dele all
pack
sele 7
go top
dele all
pack

select 3
use wyrab2 index wyrab2
go top
select 7
use wyrab4
go top
   ii=1
   do while ii < 13
      sele 7
      xx1=ego2
      skip
      sele 3
      repl mim with xx1
      skip
      ii=ii+1
   enddo
   select 7
   use wyrab4
   go top
   ii=1
   do while ii < 13
      sele 7
      xx1=ego3
      skip
      sele 3
      repl mim with xx1
      skip
      ii=ii+1
   enddo
sele 7
go top
ii=1
sele 3
go top
skip 187
do while ii<5
   sele 7
   xx1=ego4
   skip
   sele 3
   repl mim with xx1
   skip
   ii=ii+1
enddo
sele 1
use akt2
go top
lld=0
count to lld
if lld > 0
   do AKTNS     && Если была замена счетчика по Акту (на линиях)
endif
restore screen from ww
use
close all
prizn=0
return

procedure MAZUT
dime s(15),dat(3),tim(2),w2(15),w1(15),t(15),ro(15),ur(15),rc(15)
dime nbak(15),rmac(15),mac(15),mpr(15)
nbak=0
mpr=0
s(1)=921.501
s(2)=919.619
s(3)=920.856
s(4)=920.157
s(5)=919.243
s(6)=919.995
s(7)=920.157
s(8)=408.676
s(9)=406.565
s(10)=407.924
s(11)=408.031
s(12)=407.137
s(13)=408.390
s(14)=152.0
s(15)=152.0
prh=0
@ 15,16,21,62 box win1+" "
rr=1
@ 16,18 prompt " Просто расчет "
@ 16,36 prompt " Расчет с корректировкой "
menu to rr
do case
case rr=0
return
case rr=2
prh=1
endcase
dat(1)=1
dat(2)=1
dat(3)=1995
tim(1)=12
tim(2)=0
s1=0
s2=0
@ 17,18 say "Дата инвентаризации: ДД,ММ,ГГГГ"
@ 18,18 say "Время инвентаризации: ЧАС,МИ"
@ 19,23 say "ПРИХОД           РАСХОД"
@ 17,51 get dat(1) pict "999"
@ 17,55 get dat(2) pict "999"
@ 17,59 get dat(3) pict "9999"
@ 18,53 get tim(1) pict "999"
@ 18,57 get tim(2) pict "999"
@ 19,30 get s1 pict "999999"
@ 19,47 get s2 pict "9999999"
read
l=readkey()
if l=12
return
endif
save screen to grpgrp
use maz1 index maz1
go top
do REDMAZ
restore screen from grpgrp
ssum=0.0
go top
do while ! eof()
j=nomer
ur(j)=rur
ro(j)=rro
t(j)=rt
w1(j)=rw1
w2(j)=rw2
rc(j)=s(j)/(100.0-w2(j))
rmac(j)=rc(j)*ur(j)*(ro(j)-0.0006*(t(j)-20.0))*(100.0-w1(j))+0.5
mac(j)=int(rmac(j))
ssum=ssum+mac(j)
skip
enddo
s3=ssum+s1+s2
s4=s3
nsum=ssum
do PETMAZ
if l=27.or.rr=1
return
endif
prh=2
rr=1
@ 20,18 prompt " Корректировать "
@ 20,40 prompt " Е корректировать "
menu to rr
if rr=0
return
endif
if rr=2
rr=0
endif
if rr=0
ssum=nsum
s3=s4
do PETMAZ
return
endif
set color to r+//b
@ 24,25 say "Окончательный вес ?   "
@ 24,47 get s4 pict "99999999"
read
raz=s4-s3
set color to w+//b
@ 0,0,24,79  box "░"
set color to r+//b
@ 24,3 say "омера баков без изменений ?"
@ 24,32 get nbak(1) pict "99"
@ 24,35 get nbak(2) pict "99"
@ 24,38 get nbak(3) pict "99"
@ 24,41 get nbak(4) pict "99"
@ 24,44 get nbak(5) pict "99"
@ 24,47 get nbak(6) pict "99"
@ 24,50 get nbak(7) pict "99"
@ 24,53 get nbak(8) pict "99"
@ 24,56 get nbak(9) pict "99"
@ 24,59 get nbak(10) pict "99"
@ 24,62 get nbak(11) pict "99"
@ 24,65 get nbak(12) pict "99"
@ 24,68 get nbak(13) pict "99"
@ 24,71 get nbak(14) pict "99"
@ 24,74 get nbak(15) pict "99"
read
set color to w+//b
@ 0,0,24,79  box "░"
kol=0
i=1
do while i<16
j=nbak(i)
if j=0
exit
endif
kol=kol+1
mpr(j)=1
i=i+1
enddo
kol=15-kol
dov=raz/kol
i=1
do while i<16
if mpr(i)=0
rmac(i)=rmac(i)+dov
endif
mac(i)=int(rmac(i))
i=i+1
enddo
rr=1
@ 24,3 say "Что изменять ?   "
@ 24,21 prompt "   Уровень   "
@ 24,35 prompt "  Плотность  "
@ 24,49 prompt " Температурa "
@ 24,63 prompt "  Влажность  "
menu to rr
@ 0,0,24,79  box "░"
do while .t.
   i=1
   do while i<16
   if mpr(i)=0
   do case
   case rr=1.or.rr=0
   ur(i)=rmac(i)/(rc(i)*(ro(i)-0.0006*(t(i)-20.0))*(100.0-w1(i)))
   case rr=2
   ro(i)=rmac(i)/(rc(i)*ur(i)*(100.0-w1(i)))+0.0006*(t(i)-20.0)
   case rr=3
   tt=(ro(i)-rmac(i)/(rc(i)*ur(i)*(100.0-w1(i))))/0.0006+20.0
   case rr=4
   w1(i)=100.0-rmac(i)/(rc(i)*ur(i)*(ro(i)-0.0006*(t(i)-20.0)))
   endcase
   endif
   i=i+1
   enddo
   nsum=0
   i=1
   do while i<16
   nsum=nsum+mac(i)
   i=i+1
   enddo
   ns3=nsum+s1+s2
   iraz=0
   if ns3#s4
      iraz=s4-ns3
      if s1=0.and.s2=0
         i=15
         do while i>0
            if mpr(i)=0
               rmac(i)=rmac(i)+iraz
               mac(i)=mac(i)+iraz
               exit
            endif
            i=i-1
         enddo
         loop
      endif
      if s1#0.or.s2#0
         if abs(s1)>=abs(s2)
         s1=s1+iraz
         endif
         if abs(s1)<abs(s2)
         s2=s2+iraz
         endif
      endif
      exit
   endif
   exit
enddo
ssum=nsum
s3=s4
do PETMAZ
return
