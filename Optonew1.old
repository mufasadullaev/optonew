procedure CLERR
clear
@ 13,38,16,77 box win1+" "
@ 14,40 say "Укажите дату: ДД,ММ,ГГГГ"
@ 14,64 get idd pict "999"
@ 14,68 get imm pict "999"
@ 14,72 get igg pict "9999"
read
if year(date())#igg
   wait "ОШИБКА,проверьте год !!!"
*   @ 15,5 say "ОШИБКА,проверьте год !!!"
   return
endif
l=readkey()
if l=12
return
endif
otz=1
@ 15,43 say "ПЕРВый  или  ПОВТорный расчет?"
@ 15,43 prompt "ПЕРВ"
@ 15,56 prompt "ПОВТ"
menu to otz
if otz=0
return
endif
ddd=idd+imm*100
ddd1=imm+idd*100   && для аржива
if otz=1
i=1
do while i<=8
if mshe(i)=ddd
@ 16,38,20,77 box win1+" "
@ 17,39 say "За эту дату был первый расчет"
@ 18,40 say "Оставить дату: ДД,ММ,ГГГГ"
@ 18,64 say idd pict "999"
@ 18,68 say imm pict "999"
@ 18,72 say igg pict "9999"
ozz=1
@ 19,43 say "ОШИБКА  или  ПОВТорный расчет?"
@ 19,43 prompt "ОШИБКА"
@ 19,56 prompt "ПОВТ"
menu to ozz
if ozz=0
return
endif
if ozz=1
return
endif
if ozz=2
otz=2
endif
exit
endif
i=i+1
enddo
endif
if otz=1.or.otz=2
i=1
do while i<=8
if mpat(i)=1
if i=1
i=9
exit
endif
exit
endif
i=i+1
enddo
if  round(mshe(i-1),-2)=imm*100
if ddd>=mshe(i-1)+2
@ 10,40,13,77 box win1+" "
@ 11,53 say "Неверная дата"
@ 12,47 say "Нарушится график вахт"
read
l=readkey()
return
endif
if otz=2
if ddd=mshe(i-1)+1
@ 10,40,13,77 box win1+" "
@ 11,49 say "Неверный выбор расчета"
@ 12,46 say "Нарушится нарастающая сумма"
read
l=readkey()
return
endif
endif
else
if idd#1
if otz=1
@ 10,40,13,77 box win1+" "
@ 11,53 say "Неверная дата"
@ 12,47 say "Нарушится график вахт"
read
l=readkey()
return
endif
endif
endif
if idd=1
@ 10,40,13,77 box win1+" "
ooo=1
@ 11,53 say "Менять месяц"
@ 12,53 prompt "ДА"
@ 12,62 prompt "НЕТ"
menu to ooo
if ooo=0
return
endif
if ooo=2
return
endif
if ooo=1
if otz=2
if ddd=mshe(i-1)+1
@ 10,40,13,77 box win1+" "
@ 11,49 say "Неверный выбор расчета"
@ 12,46 say "Нарушится нарастающая сумма"
read
l=readkey()
return
endif
endif
endif
endif
endif
*if ozz=2
*otz=2
*endif
data=idd+imm*100+igg*10000
select 3

go top
*skip            && исправить ЛИЗА
min=nome
go bott
max=nome
go top
do while ! eof()

if nome=data
   fff=data
   do while .t.
      do FILTER
      do FILTER1
      do FILTER2
      clear
      men=2
      @13,20 say "Продолжать редактирование (ESC-выход без расчета)"
      @14,30 prompt "ДА"
      @14,43 prompt "НЕТ"
      menu to men
      if men=0
         return
      endif
       if men=1
          loop
       endif
        if men=2
           exit
        endif
   enddo
clear

@ 13,20 say "Ждите! Идет обработка информации"
exit
endif
skip
enddo
if data<min
   clear
   @ 5,15 say "ИСХОДНЫХ ДАННЫХ ЗА ЭТО ЧИСЛО НЕТ"
   @ 6,15 say "НАЖМИТЕ ЛЮБУЮ КЛАВИШУ"
   i=inkey(0)
   return
endif
if data>max
   fff=min
   do while .t.
   do FILTER
   do FILTER1
   do FILTER2
   clear
   men=2
   @ 13,20 say "Продолжать редактирование (ESC-выход без расчета)"
   @ 14,30 prompt "ДА"
   @ 14,43 prompt "НЕТ"
   menu to men
   if men=0
      return
   endif
    if men=1
       loop
    endif
     if men=2
        exit
     endif
   enddo
clear
@ 13,20 say "Ждите! Идет обработка информации"
endif
select 2
use wyrab2
go top
i=1
do while ! eof()
nsi(i)=ks
i=i+1
skip
enddo
select 4
use baxta4
go top
i=1
do while ! eof()
mkl1(i)=kl1
mkl2(i)=kl2
mkf1(i)=kf1
mkf2(i)=kf2
mkf3(i)=kf3
mkf4(i)=kf4
i=i+1
skip
enddo
select 5
use baxta5
go top
sz1=z1
select 8
use baxta50
if otz=1
i=1
do while i<=8
   if mpat(i)=1
      exit
   endif
   i=i+1
enddo
j=i
mpat(j)=0
mshe(j)=ddd
select 6
go top
skip j-1
repl pat with mpat(j),she with mshe(j)
wah(1)=mraz(j)
wah(2)=mdwa(j)
wah(3)=mtri(j)
j=j+1
if j=9
j=1
endif
mpat(j)=1
go top
skip j-1
repl pat with mpat(j)
endif
if otz=2
select 8
go top
i=1
do while ! eof()
sut2(i)=mmdds
if sut2(i)=ddd
sut2(i)=0
repl mmdds with sut2(i)
endif
i=i+1
skip
enddo
i=1
do while i<=8
if mshe(i)=ddd
wah(1)=mraz(i)
wah(2)=mdwa(i)
wah(3)=mtri(i)
exit
endif
i=i+1
enddo
endif
i=1
do while i<13
mnb(i)=i
i=i+1
enddo
i=1
do while (i<=12)
c=nsi(mnb(i))*0.001
j=1
k=0
do while (j<=3)
wyr(i,j)=0
d=100000
if (mpw(i*4-j)#mpw(i*4-k))
wyr(i,j)=(mpw(i*4-j)-mpw(i*4-k))
endif
if (mpw(i*4-k)>mpw(i*4-j))
wyr(i,j)=wyr(i,j)+d
endif
wyr(i,j)=wyr(i,j)*c
k=k+1
if k=3
exit
endif
j=j+1
enddo
i=i+1
enddo
i=1
do while (i<=12)
c=nsi(mnb(i)+12)*0.001
j=1
k=0
do while (j<=3)
esn(i,j)=0
*d=1000000
*9999
*?'j='+str(j)
*? 'mps(j*4-j)='+str(mps(j*4-j))
*?'k='+str(k)
*? 'mps(j*4-k)='+str(mps(j*4-k))
*wait "before"
*9999
d=1000000
if (mps(i*4-j)#mps(i*4-k))
esn(i,j)=(mps(i*4-j)-mps(i*4-k))
endif
if (mps(i*4-k)>mps(i*4-j))
esn(i,j)=esn(i,j)+d
endif
esn(i,j)=esn(i,j)*c
k=k+1
if k=3
exit
endif
j=j+1
*9999
*?'j='+str(j)
*?'d='+str(d)
*?'c='+str(c)
*? 'mps(j*4-j)='+str(mps(j*4-j))
*?'k='+str(k)
*? 'mps(j*4-k)='+str(mps(j*4-k))
*wait "after"
*9999
enddo
i=i+1
enddo
prom=0
nnz=sz1
if sz1#2
nnz=sz1+1
endif
j=1
i=1
kol=0
do while i<=3
if ntim(i)=0
cif1(2,j)=0
j=j+1
i=i+1
loop
endif
eksut8(i)=wyr(nnb(i),j)/ntim(i)
cif1(1,j)=ntn(i)
prom=prom+eksut8(i)
cif1(2,j)=eksut8(i)
cif1(2,j)=round(cif1(2,j),0)
do SCHET
cif1(3,4)=cif1(3,4)+eksut1(i)
cif1(4,4)=cif1(4,4)+eksut2(i)
cif1(5,4)=cif1(5,4)+eksut3(i)
cif1(6,4)=cif1(6,4)+eksut4(i)
cif1(7,4)=cif1(7,4)+eksut5(i)
cif1(8,4)=cif1(8,4)+eksut6(i)
cif1(9,4)=cif1(9,4)+eksut7(i)
cif1(3,j)=eksut1(i)
cif1(3,j)=round(cif1(3,j),0)
cif1(4,j)=eksut2(i)
cif1(4,j)=round(cif1(4,j),0)
cif1(5,j)=eksut3(i)
cif1(5,j)=round(cif1(5,j),0)
cif1(6,j)=eksut4(i)
cif1(6,j)=round(cif1(6,j),0)
cif1(7,j)=eksut5(i)
cif1(7,j)=round(cif1(7,j),0)
cif1(8,j)=eksut6(i)
cif1(8,j)=round(cif1(8,j),0)
cif1(9,j)=eksut7(i)
cif1(9,j)=round(cif1(9,j),0)
do ZAMBAX
nnz=nnz+1
if nnz=2501
nnz=2
endif
j=j+1
i=i+1
kol=kol+1
enddo
cif1(2,4)=0
if kol#0
cif1(2,4)=prom/kol
cif1(2,4)=round(cif1(2,4),0)
endif
cif1(3,4)=round(cif1(3,4),0)
cif1(4,4)=round(cif1(4,4),0)
cif1(5,4)=round(cif1(5,4),0)
cif1(6,4)=round(cif1(6,4),0)
cif1(7,4)=round(cif1(7,4),0)
cif1(8,4)=round(cif1(8,4),0)
cif1(9,4)=round(cif1(9,4),0)
prom=0
j=1
i=4
kol=0
do while i<7
if ntim(i)=0
cif2(2,j)=0
j=j+1
i=i+1
loop
endif
eksut8(i)=wyr(nnb(i),j)/ntim(i)
cif2(1,j)=ntn(i)
prom=prom+eksut8(i)
cif2(2,j)=eksut8(i)
cif2(2,j)=round(cif2(2,j),0)
do SCHET
cif2(3,4)=cif2(3,4)+eksut1(i)
cif2(4,4)=cif2(4,4)+eksut2(i)
cif2(5,4)=cif2(5,4)+eksut3(i)
cif2(6,4)=cif2(6,4)+eksut4(i)
cif2(7,4)=cif2(7,4)+eksut5(i)
cif2(8,4)=cif2(8,4)+eksut6(i)
cif2(9,4)=cif2(9,4)+eksut7(i)
cif2(3,j)=eksut1(i)
cif2(3,j)=round(cif2(3,j),0)
cif2(4,j)=eksut2(i)
cif2(4,j)=round(cif2(4,j),0)
cif2(5,j)=eksut3(i)
cif2(5,j)=round(cif2(5,j),0)
cif2(6,j)=eksut4(i)
cif2(6,j)=round(cif2(6,j),0)
cif2(7,j)=eksut5(i)
cif2(7,j)=round(cif2(7,j),0)
cif2(8,j)=eksut6(i)
cif2(8,j)=round(cif2(8,j),0)
cif2(9,j)=eksut7(i)
cif2(9,j)=round(cif2(9,j),0)
do ZAMBAX
nnz=nnz+1
if nnz=2501
nnz=2
endif
j=j+1
i=i+1
kol=kol+1
enddo
cif2(2,4)=0
if kol#0
cif2(2,4)=prom/kol
cif2(2,4)=round(cif2(2,4),0)
endif
cif2(3,4)=round(cif2(3,4),0)
cif2(4,4)=round(cif2(4,4),0)
cif2(5,4)=round(cif2(5,4),0)
cif2(6,4)=round(cif2(6,4),0)
cif2(7,4)=round(cif2(7,4),0)
cif2(8,4)=round(cif2(8,4),0)
cif2(9,4)=round(cif2(9,4),0)
prom=0
j=1
i=7
kol=0
do while i<10
if ntim(i)=0
cif3(2,j)=0
j=j+1
i=i+1
