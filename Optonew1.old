@ 20,50 get r pict "99.9999"
read
l=readkey()
if l=12
return
endif
liz2 = igrp*10+init           && номер грп и номер нитки
ddt=2
@ 21,22 prompt " Уничтожать данные "
@ 21,42 prompt " Не уничтожать "
menu to ddt
if ddt=0
return
endif
if ddt=1
sele 3            && use grp3 index grp3
go top
skip
do while ! eof()
dele
skip
enddo
pack
go top
endif
select 2          && use grp2
go top
i=1
do while ! eof()
f(i)=ff
i=i+1
skip
enddo
go top
do case
case igrp=1
i=1
do while ! eof()
if otz=2
pd(i)=dn2
i=i+1
skip
loop
endif
if init=1
pd(i)=pd11
endif
if init=2
pd(i)=pd12
endif
if init=3
pd(i)=pd13
endif
if init=4
pd(i)=pd14
endif
i=i+1
skip
enddo
case igrp=2
i=1
do while ! eof()
if otz=2
pd(i)=dn2
i=i+1
skip
loop
endif
if init=1
pd(i)=pd21
endif
if init=2
pd(i)=pd22
endif
if init=3
pd(i)=pd23
endif
if init=4
pd(i)=pd24
endif
i=i+1
skip
enddo
case igrp=3
i=1
do while ! eof()
if init=1
pd(i)=pd31
endif
if init=2
pd(i)=pd32
endif
if init=3
pd(i)=pd33
endif
if init=4
pd(i)=pd34
endif
i=i+1
skip
enddo
case igrp=4
i=1
do while ! eof()
if init=1
pd(i)=pd41
endif
if init=2
pd(i)=pd42
endif
if init=3
pd(i)=pd43
endif
if init=4
pd(i)=pd44
endif
i=i+1
skip
enddo
endcase
save screen to grpgrp
if liz = 2
      @ 16,20,22,58 box win1+" "
      @ 18,22 say "Введите расход газа для разброса"
      @ 19,22 say " 0 - просто корректировка -"
      @ 19,50 get liz5 pict "9999.99"
      read
   sele 4         && use grp4 index grp4
*   seek liz1
   set filter to mesgod = liz1 .and. nit = liz2
   lld = 0
   count to lld
   if lld = 0
      @ 16,20,22,58 box win1+" "
      @ 18,22 say "НЕТ данных для коррекрировки!!!"
      @ 20,22 say "Нажмите любую клавишу !"
      read
      restore screen from ww
      return
   endif
   select 3
   go top
   dele all
   pack
   sele 4
browse
wait
   go top
   liz6 = 0
   do while ! eof()
      if liz5 # 0
         liz6 = liz6+qq
      endif
      baz1 = nomer
      baz2 = qq
      baz3 = p
      baz4 = t
      select 3
      append blank
      repl nomer with baz1
      repl qq with baz2
      repl p with baz3
      repl t with baz4
      skip
      select 4
      skip
   enddo
*suspe
   select 4
   go top
   dele all
   pack
endif
if liz5 # 0
   liz7 = liz5/liz6
   select 3
   go top
   do while ! eof()
     repl qq with round((qq+qq*liz7),1)
     skip
   enddo
endif
select 3
go top
do REDGRP
go top
restore screen from grpgrp
set printer to grp.pec
set device to print
str=prow()+2
@ str,0 say "ИВЦ    ТошДИЭС"
@ str,45 say "Р А С Х О Д   Г А З А"
if otz=1
@ str,70 say "ГРП"
else
@ str,70 say "ГРС"
endif
@ str,74 say igrp pict "99"
@ str,77 say "нитка"
  if liz2=24                      && изм 6.05.98г
    @ str,84 say "2-Подшкальник"  && на 4 нитке 2 ГРП
    else
@ str,83 say init pict "99"
  endif
@ str,115 say "Дата"
@ str,120 say idd pict "99"
@ str,122 say "."
@ str,123 say imm pict "99"
@ str,125 say "."
@ str,126 say igg pict "9999"
str=str+2
@ str,0 say "Барометрическое давление"
@ str,25 say pl pict "999.999"
@ str,35 say "Плотность"
@ str,45 say r pict "999.999"
  if liz2=24                      && изм 6.05.98г
    @ str,84 say "KQ=1.055262"    && на 4 нитке 2 ГРП
  endif
str=str+1
@ str,122 say "Тыс.МЗ"
str=str+1
@ str,0 say "Час       QD        P      T        PA      XИ       EPD       N        KT        KRE       KPT       KRO      ДельK       Q Расч"
str=str+1
es=pd(2)**2
*p2=pl/760.0000
p2=pl*1.3595/1000       && испр.1.03.98г
sumc=0.0
sumx=0.0
sume=0.0
suman=0.0
sumd=0.0
sums=0.0
sumak9=0.0
sumak1=0.0
sumh=0.0
sumv9=0.0
do while ! eof()
n=nomer
pp(n)=p
pt(n)=t
q(n)=qq
ak(n)=0
v(n)=0
c=0.0000
c=p+p2
x=1.29+0.704*(2575+(346.23-(273.15+t))**2)*c/1000000
*e=1-(0.41+0.35*es)*qq**2/(pd(14)**2*c*x/1000000)  &&  KKK
e=0.9887*(1-(0.41+0.35*es)*qq**2/(pd(14)**2*c*x/1000000))
an=0.0000
an=qq/pd(1)
d=1.001
if (t-51.8)<0
d=0.9987
if (t+14.9)>0
j=23
d=1.0012
do while .t.
j=j-1
d=d-0.0001
if (t-f(j))>0
exit
endif
enddo
endif
endif
* p6=30.168*(0.05993*(26.831-r)+(pd(6)-0.392*pd(7)))
p6=30.168*(0.05993*(26.831-r)+(pd(6)+0.392*pd(7)))
t2=88.25*(1.7591*(0.56364+r)-(pd(6)+1.681*pd(7)))
t3=(t+273.15)/t2
p3=c/p6
am2=(0.5173*(1+r*(1.104-0.25*r)))*(t3*(1-0.1038*t3)+0.037)*(1+p3**2/30/(t3-1))/1000000
ak1=sqrt(1/r)
ak2=226.29/(175.91*(0.56364+r)-100*(pd(6)+1.681*pd(7)))
*ak3=156.47/(5.993*(26.831-r)+100*(pd(6)-0.392*pd(7)))
ak3=156.47/(5.993*(26.831-r)+100*(pd(6)+0.392*pd(7)))
p4=p*ak3
t4=ak2*(t+273.15)-273.15
i1= -15
do while i1<=35
ai1=i1
if (ai1-t4)>=0
exit
endif
i1=i1+5
enddo
ai2=ai1-5
ai3=t4-ai2
ib1=2
do while ib1<=20
b1=ib1/2
if (b1-p4)>=0
exit
endif
ib1=ib1+1
enddo
b2=b1-0.5
b11=p4-b2
i1=ai1/5+4
if (ai1-t4) <> 0
ib=b1*2-1
i2=ai2/5+4
ib2=b2*2-1
if i1<1
i1=1
endif
if i2<1
i2=1
endif
if ib<1
ib=1
endif
if ib1<1
ib1=1
endif
if ib2<1
ib2=1
endif
b3=(ggg(i1,ib)-ggg(i2,ib))/5
b3=b3*ai3+ggg(i2,ib)
b4=(ggg(i1,ib2)-ggg(i2,ib2))/5
b4=b4*ai3+ggg(i2,ib2)
h=(b3-b4)*2*b11+b4
else
ib1=b1*2-1
h=ggg(i1,ib1)
endif
*h=sqrt(1/h)      && KKKK
h=0.9994*sqrt(1/h)
ak9=0.0000
ak9=sqrt(c/(t+273.1500))
q2=pd(15)*an*e*d*ak9*ak1*h
r1=0.0361*q2*r/(pd(4)*am2)
c3=0.5959+0.0312*(pd(2)**1.05)-0.184*(es**2)
c3=c3/sqrt(1-es)
b4=0.0029*(pd(2)**1.25)/(sqrt(1-es))
s1=b4*r1/(pd(13)*1000000)
s2=c3*r1/(pd(13)*1000000)
s3=s1/s2**1.75
r2=r1*c3/(pd(13)*(1-s3*(1-s3*(1-s3)**1.75)**1.75))
*s=(c3+b4*(1000000/r2)**0.75)/(c3+b4)    && KKKK
s=0.9991*((c3+b4*(1000000/r2)**0.75)/(c3+b4))
v9(n)=q2*s/1000
  if liz2=24                      && изм 6.05.98г
    v9(n)=v9(n)*1.055262          && на 4 нитке 2 ГРП
  endif
@ str,0 say n pict "99"                 &&  час
@ str,3 say qq pict "9999999.99"        &&  QD
@ str,14 say p pict "99999.99"          &&  P
@ str,23 say t pict "9999.9"            &&  T
@ str,31 say c pict "9999.999"           && PA
@ str,39 say x pict "9999.999"          &&
@ str,48 say e pict "9999.9999"         &&
@ str,58 say an pict "999.9999"         &&
@ str,67 say d pict "9999.9999"         &&
@ str,77 say s pict "9999.9999"         &&
@ str,87 say ak9 pict "9999.9999"       &&
@ str,97 say ak1 pict "9999.9999"       &&
@ str,107 say h pict "9999.9999"        &&
@ str,117 say v9(n) pict "9999999.9999"
str=str+1
sumc=sumc+c
sumx=sumx+x
sume=sume+e
suman=suman+an
sumd=sumd+d
sums=sums+s
sumak9=sumak9+ak9
sumak1=sumak1+ak1
sumh=sumh+h
sumv9=sumv9+v9(n)
skip
enddo
n=26
ccc=0
v6=0.0
q8=0.0
av=0.0
p8=0.0
t8=0.0
ak8=0.0
i=1
do while i<26
if q(i)>0
ccc=ccc+1
v6=v6+v9(i)
av=av+v(i)
v(n)=av/ccc
q8=q8+q(i)
p8=p8+pp(i)
t8=t8+pt(i)
ak8=ak8+ak(i)
endif
i=i+1
enddo
ppp=p8/ccc
ttt=t8/ccc
ak(n)=ak8/ccc
str=str+1
@ str,0 say "Количество газа потребляемого за сутки"
@ str,40 say v6 pict "9999999.9999"
str=str+1
c=sumc/ccc
x=sumx/ccc
e=sume/ccc
an=suman/ccc
d=sumd/ccc
s=sums/ccc
ak9=sumak9/ccc
ak1=sumak1/ccc
h=sumh/ccc
summ(init,igrp)=v6
@ str,0 say "СР"
@ str,3 say q8 pict "9999999.99"
@ str,14 say ppp pict "99999.99"
@ str,23 say ttt pict "99999.9"
@ str,30 say c pict "9999.999"
@ str,39 say x pict "9999.999"
@ str,48 say e pict "9999.9999"
@ str,58 say an pict "999.9999"
@ str,67 say d pict "9999.9999"
@ str,77 say s pict "9999.9999"
@ str,87 say ak9 pict "9999.9999"
@ str,97 say ak1 pict "9999.9999"
@ str,107 say h pict "9999.9999"
c=ppp+p2
x=1.29+0.704*(2575+(346.23-(273.15+ttt))**2)*c/1000000
* e=1-(0.41+0.35*es)*(q8/ccc)**2/(pd(14)**2*c*x/1000000) &&  KKKK
e=0.9887*(1-(0.41+0.35*es)*(q8/ccc)**2/(pd(14)**2*c*x/1000000))
an=(q8/ccc)/pd(1)
d=1.001
if (ttt-51.8)<0
d=0.9987
if (ttt+14.9)>0
j=23
d=1.0012
do while .t.
j=j-1
d=d-0.0001
if (ttt-f(j))>0
exit
endif
enddo
endif
endif
* p6=30.168*(0.05993*(26.831-r)+(pd(6)-0.392*pd(7)))
p6=30.168*(0.05993*(26.831-r)+(pd(6)+0.392*pd(7)))
t2=88.25*(1.7591*(0.56364+r)-(pd(6)+1.681*pd(7)))
t3=(ttt+273.15)/t2
p3=c/p6
am2=(0.5173*(1+r*(1.104-0.25*r)))*(t3*(1-0.1038*t3)+0.037)*(1+p3**2/30/(t3-1))/1000000
ak1=sqrt(1/r)
ak2=226.29/(175.91*(0.56364+r)-100*(pd(6)+1.681*pd(7)))
* ak3=156.47/(5.993*(26.831-r)+100*(pd(6)-0.392*pd(7)))
ak3=156.47/(5.993*(26.831-r)+100*(pd(6)+0.392*pd(7)))
p4=ppp*ak3
t4=ak2*(ttt+273.15)-273.15
i1= -15
do while i1<=35
ai1=i1
if (ai1-t4)>=0
exit
endif
i1=i1+5
enddo
ai2=ai1-5
ai3=t4-ai2
ib1=2
do while ib1<=20
b1=ib1/2
if (b1-p4)>=0
exit
endif
ib1=ib1+1
enddo
b2=b1-0.5
b11=p4-b2
i1=ai1/5+4
if (ai1-t4) <> 0
ib=b1*2-1
i2=ai2/5+4
ib2=b2*2-1
if i1<1
i1=1
endif
if i2<1
i2=1
endif
if ib<1
ib=1
endif
if ib1<1
ib1=1
endif
if ib2<1
ib2=1
endif
b3=(ggg(i1,ib)-ggg(i2,ib))/5
b3=b3*ai3+ggg(i2,ib)
b4=(ggg(i1,ib2)-ggg(i2,ib2))/5
b4=b4*ai3+ggg(i2,ib2)
h=(b3-b4)*2*b11+b4
else
ib1=b1*2-1
h=ggg(i1,ib1)
endif
*h=sqrt(1/h)         && KKKK
h=0.9994*sqrt(1/h)
ak9=sqrt(c/(ttt+273.15))
q2=pd(15)*an*e*d*ak9*ak1*h
r1=0.0361*q2*r/(pd(4)*am2)
c3=0.5959+0.0312*(pd(2)**1.05)-0.184*(es**2)
c3=c3/sqrt(1-es)
b4=0.0029*(pd(2)**1.25)/(sqrt(1-es))
s1=b4*r1/(pd(13)*1000000)
s2=c3*r1/(pd(13)*1000000)
s3=s1/s2**1.75
r2=r1*c3/(pd(13)*(1-s3*(1-s3*(1-s3)**1.75)**1.75))
*s=(c3+b4*(1000000/r2)**0.75)/(c3+b4)   &&  KKKK
s=0.9991*((c3+b4*(1000000/r2)**0.75)/(c3+b4))
sumv9=ccc*q2*s/1000
  if liz2=24                      && изм 6.05.98г
    sumv9=sumv9*1.055262          && на 4 нитке 2 ГРП
  endif
d8=(sumv9-v6)/v6*100
@ str,117 say sumv9 pict "9999999.9999"
