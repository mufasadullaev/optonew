procedure REDWYR
clear
@ 0,0 say  "╔════╦═════════╦═════════╦═════════╦═══════════╦══════════╗"
@ 1,0 say  "║  N ║ Э/Э нач.║ Э/Э кон.║Э/Э С н.║ Э/Э С к. ║ОТРАБ.ЧАСЫ║ "
@ 2,0 say  "╠════╬═════════╬═════════╬═════════╬═══════════╬══════════╣"
@ 15,0 say "╠════╩═════════╬═════════╩═════════╩═══════════╩══════════╣"
@ 20,0 say "╚══════════════╩══════════════════════════════════════════╝"
kol=3
@ 24,0 say re pict ""
mini=1
maxi=12
go top
do WYREKR
go top
kol = 3
i=1
do while .t.
*@ kol,17 get pkw pict "9999999"
@ kol,17 get pkw pict "999999.9" && 01112004
*@ kol,37 get pks pict "999999.99"
@ kol,36 get pks pict "999999.99"
@ kol,52 get timk pict "99"
read
l = readkey()
*@ kol,17 say pkw pict "9999999"
@ kol,17 say pkw pict "999999.9" && 01112004
*@ kol,37 say pks pict "999999.99"
@ kol,36 say pks pict "999999.99"
@ kol,52 say timk pict "99"
if l = 12       &&  esc
 exit
endif
if l = 36         && f1+
nom=nomer
nm=0
lll=0
do while .t.
l=inkey(0)
if l<45 .or.l>57 .or. l=46 .or. l=47
exit
endif
if l=45
lll=1
else
nm=nm*10+l-48
endif
enddo
if lll=1
nm=0-nm
endif
if nm < mini .or. nm > maxi
loop
endif
seek nm
if ! found()
seek nom
loop
endif
kol=3
do WYREKR
seek nm
kol=3
loop
endif
if l = 4                      &&    стрелка вв.
if nomer = mini
loop
endif
skip -1
nom=nomer
nm=kol-1
if kol > 3
kol = kol - 1
loop
else
kol=3
do WYREKR
seek nom
kol=nm
endif
loop
endif
if l=34                    &&  ус.PgUp
if nomer = mini
loop
endif
seek mini
kol=3
do WYREKR
seek mini
kol=3
loop
endif
if l=35                    &&  ус.PgDn
if nomer = maxi
loop
endif
go top
kol=3
do WYREKR
seek maxi
kol=14
loop
endif
if l=6                     &&    PgUp
if nomer = mini
loop
endif
kol=3
go top
do WYREKR
go top
kol=3
loop
endif
if l=7                     &&   PgDn
if nomer = maxi
loop
endif
go top
kol=3
do WYREKR
seek maxi
kol=14
loop
endif
if l=5.or.l=270.or.l=15    && ус.end,enter,стрелка вн.
if nomer = maxi
   loop
endif
skip
kol=kol+1
loop
endif
enddo
do TRAEK
return
procedure REPLW
go top
kol = 3
i=1
do while ! eof()
@ kol,17 get qq1 pict "9999999"
@ kol,37 get qq2 pict "999999.9"
@ kol,52 get qq3 pict "99"
read
repl pkw with qq1
repl pks with qq2
repl timk with qq3
skip
kol=kol+1
enddo
procedure WYREKR
@ kol,0 clear to 14,79
@ 16,0 clear to 20,79
i=1
*select 1
*go top
do while ! eof()
@ kol,0 say "║"
@ kol,2 say nomer pict "99"
@ kol,5 say "║"
*@ kol,7 say pnw pict "999999"
@ kol,7 say pnw pict "999999.9" && 01112004
@ kol,15 say "║"
*@ kol,17 say pkw pict "999999"
@ kol,17 say pkw pict "999999.9" && 01112004
@ kol,25 say "║"
*@ kol,27 say pns pict "999999.9"
@ kol,26 say pns pict "999999.99"
@ kol,35 say "║"
*@ kol,37 say pks pict "999999.9"
@ kol,36 say pks pict "999999.99"
@ kol,47 say "║"
@ kol,52 say timk pict "99"
@ kol,58 say "║"
i=i+1
if kol>13
exit
endif
kol = kol + 1
skip
enddo
return
procedure TRAEK
kol=16
nm=kol
@ kol,0 say "║"
@ kol,1 say "ТР-РЫ"
@ kol,8 say " Э/Э н."
@ kol,15 say "║"
@ kol,17 say " Э/Э к."
@ kol,58 say "║"
kol=kol+1
@ kol,0 say "╠══════════════╬══════════════════════════════════════════╣"
kol=kol+1
@ kol,2 say "ТС-20"
kol = kol + 1
@ kol,2 say "ТС-30"
kol = kol + 1
@ kol,2 say "3ТР-А"
kol = kol + 1
@ kol,2 say "3ТР-В"
kol=kol+1
kol = nm
go top
i=1
kol=18
do while .t.
@ kol,0  say "║"
@ kol,8 say trns pict "9999.99"
@ kol,15 say "║"
@ kol,17 say trks pict "9999.99"
@ kol,58 say "║"
kol=kol+1
skip
i=i+1
if i>4
   exit
endif
enddo
@ 22,0 say "╚══════════════╩══════════════════════════════════════════╝"
kol=18
go top
mini=1
maxi=4
do while .t.
@ kol,17 get trks pict "9999.99"
read
l = readkey()
@ kol,17 say trks pict "9999.99"
if l = 12       &&  esc
 exit
endif
if l=5.or.l=270.or.l=15    && ус.end,enter,стрелка вн.
if nomer = maxi
   loop
endif
skip
kol=kol+1
loop
endif
if l = 4                      &&    стрелка вв.
if nomer = mini
loop
endif
skip -1
kol=kol-1
endif
enddo
return

