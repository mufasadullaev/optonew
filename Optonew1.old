else
 if ! file ('baxta1.bat')
   set printer to 'baxta1.bat'
 else
   set printer to 'baxta2.bat'
 endif
endif
set print on
imarx='C:\KARAT\OPTONOV1\DBF\'+'bax'+ltrim(str(ddd1))    
? 'arj a &imarx &imf0 -e'    
