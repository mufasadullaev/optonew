procedure REDMAZ
clear
@ 0,0 say  "╔═══╦═════════╦═════════╦═════════╦═════════╦═════════╗"
@ 1,0 say  "║ N ║ УРОВЕНЬ ║ПЛОТНОСТЬ║ ТЕМП-РА ║ ВЛАЖН.З ║ ВЛАЖН.П ║"
@ 2,0 say  "╠═══╬═════════╬═════════╬═════════╬═════════╬═════════╣"
@ 23,0 say "╚═══╩═════════╩═════════╩═════════╩═════════╩═════════╝"
kol=3
@ 24,0 say re pict ""
go top
mini=nomer
go bott
maxi=nomer
go top
do MAZEKR
go top
kol = 3
do while .t.
@ kol,7 get rur pict "999.99"
@ kol,17 get rro pict "9.999"
@ kol,27 get rt pict "999"
@ kol,37 get rw1 pict "99.9"
@ kol,47 get rw2 pict "99.9"
read
l = readkey()
@ kol,7 say rur pict "999.99"
@ kol,17 say rro pict "9.999"
@ kol,27 say rt pict "999"
@ kol,37 say rw1 pict "99.9"
@ kol,47 say rw2 pict "99.9"
if l = 12
exit
endif
if l = 36
nom=nomer
nm=0
lll=0
do while .t.
l=inkey(0)
if l<45 .or.l>57 .or. l=46 .or. l=47
exit
endif
if l=45
lll=1
else
nm=nm*10+l-48
endif
enddo
if lll=1
nm=0-nm
endif
if nm < mini .or. nm > maxi
loop
endif
seek nm
if ! found()
seek nom
loop
endif
kol=3
do MAZEKR
seek nm
kol=3
loop
endif
if l = 4
if nomer = mini
loop
endif
skip -1
nom=nomer
if kol > 3
kol = kol - 1
loop
else
kol=3
do MAZEKR
seek nom
kol=3
endif
loop
endif
if l=34
if nomer = mini
loop
endif
seek mini
kol=3
do MAZEKR
seek mini
kol=3
loop
endif
if l=35
if nomer = maxi
loop
endif
seek maxi
kol=3
do MAZEKR
seek maxi
kol=3
loop
endif
if l=6
if nomer = mini
loop
endif
i=0
do while ! bof()
skip -1
i=i+1
if i = 20
exit
endif
enddo
nom=nomer
kol=3
do MAZEKR
seek nom
kol=3
loop
endif
if l=7
if nomer = maxi
loop
endif
i=0
do while ! eof()
skip
i=i+1
if i = 20
exit
endif
enddo
if i<20
seek maxi
endif
nom=nomer
kol=3
do MAZEKR
seek nom
kol=3
loop
endif
if l=5.or.l=270.or.l=15
if nomer = 15
loop
endif
if kol<22
kol=kol+1
priz=0
else
kol=3
endif
skip
loop
endif
enddo
return
procedure MAZEKR
@ kol,0 clear to 22,79
do while ! eof()
@ kol,0 say "║"
@ kol,2 say nomer pict "99"
@ kol,4 say "║"
@ kol,7 say rur pict "999.99"
@ kol,14 say "║"
@ kol,17 say rro pict "9.999"
@ kol,24 say "║"
@ kol,27 say rt pict "999"
@ kol,34 say "║"
@ kol,37 say rw1 pict "99.9"
@ kol,44 say "║"
@ kol,47 say rw2 pict "99.9"
@ kol,54 say "║"
if kol=22
exit
endif
kol = kol + 1
skip
enddo
do while kol<23
@ kol,0  say "║"
@ kol,4  say "║"
@ kol,14 say "║"
@ kol,24 say "║"
@ kol,34 say "║"
@ kol,44 say "║"
@ kol,54 say "║"
kol=kol+1
enddo
return

procedure GRP
use
close all
baz1 = 0
baz2 = 0
baz3 = 0
baz4 = 0
select 2
use grp2
select 3
use grp3 index grp3
select 4
use grp4 index grp4
select 1
use grp1
go top
i=1
do while ! eof()
ggg(1,i)=g1
ggg(2,i)=g2
ggg(3,i)=g3
ggg(4,i)=g4
ggg(5,i)=g5
ggg(6,i)=g6
ggg(7,i)=g7
ggg(8,i)=g8
ggg(9,i)=g9
ggg(10,i)=g10
ggg(11,i)=g11
i=i+1
skip
enddo
idd=1
imm=1
igg=95
pl=0.0000
r=0.0000
summ=0
liz = 1
liz1 = 0
liz2 = 0
liz3 = 0
liz4 = 0
liz5 = 0
liz6 = 0
liz7 = 0
*! delete grp1.pec
do while .t.
save screen to ww
@ 16,20,20,58 box win1+" "
liz = 1
@ 18,22 prompt " РАСЧЕТ "
@ 18,34 prompt " КОРРектировка ?"
menu to liz
if liz = 0
 if liz4 > 0
   @ 16,20,22,58 box win1+" "
