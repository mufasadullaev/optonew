procedure HRAN     
select 3
go top
lld=0
count to lld
if lld=0
   return
endif
go top
lld=0
set filter to li0 = i
count to lld
if lld>0
   go top
   sum1=li3
   select 4
   if i<13
      repl ego2 with sum1
   endif
   if i>12 .and. i<188
      repl ego3 with sum1
   endif
   if i>187
      repl ego4 with sum1
   endif
endif
set filter to
return
procedure RASCH
zw1=0
zw2=0
j=0
ss1=0.0
ss2=0.0
ss3=0.0
ss1=v(i)
ss3=w2-w1
if ss3<0
   ss3=ss3+10e5
endif
*выработка
   kk1=ss1*ss3*0.001
   zkk1=0
   if zam=2
      zkk=i
      select 3
      go top
      lld=0
      set filter to li0=zkk
      count to lld
      if lld>0
         go top
         ss3=li3-li2
         if ss3<0
            ss3=ss3+10e5
         endif
         zw0=li1
         zkk1=(zw0*ss3+li4)*0.001
   *      zkk1=zkk1+li4
         prom=w2
         w1=li2
         w2=li3
         zw1=1
         repl li6 with prom
      select 1
*      repl pkw with w2
      endif
      set filter to
   endif
   kk1=zkk1+kk1
if t1 > 0
   kk2=kk1/t1
   else
      kk2=kk1
endif
*собст.н.
ss2=v(i+12)
ss3=s2-s1
if ss3<0
   ss3=ss3+10e4
endif
kk3=ss2*ss3*0.001
zkk1=0
if zam=2
   zkk=i+12
   select 3
   go top
   lld=0
   set filter to li0=zkk
   count to lld
   if lld>0
      go top
      ss3=li3-li2
      if ss3<0
         ss3=ss3+10e4
      endif
      zw0=li1
      zkk1=(zw0*ss3+li4)*0.001
*      zkk1=zkk1+li4
      prom=s2
      s1=li2
      s2=li3
      zw2=1
      repl li6 with prom
      select 1
*      repl pks with s2
   endif
   set filter to
endif
kk3=kk3+zkk1
if t1 > 0
   kk4=kk3/t1
   kk5=kk3/kk1*100
endif
sum1=sum1+t1
sum2=sum2+kk1
sum3=sum3+kk3
select 1
return
procedure PECH
bb1=kk1+0.05       &&  генератор
bb2=kk2+0.05
bb3=kk3+0.05       &&  сн
bb4=kk4+0.05
bb5=kk5+0.005
@ str,0 say ":"
@ str,2 say i pict "999"
@ str,6 say ss1 pict "99999"
if zw1>0
   @ str,10 say "*"
endif
*@ str,12 say w1 pict "9999999"
*@ str,20 say w2 pict "9999999"
@ str,12 say w1 pict "999999.9" && 01.112004
@ str,21 say w2 pict "999999.9" &&
@ str,29 say ss2 pict "99999"
if zw2>0
   @ str,34 say "*"
endif
*@ str,35 say s1 pict "9999999.9"
*@ str,45 say s2 pict "9999999.9"
@ str,35 say s1 pict "999999.99"
@ str,45 say s2 pict "999999.99"
