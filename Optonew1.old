j=1
do while j<8
@ str,8 say j pict "9"
@ str,9 say  s(j) pict "99999.999"
@ str,18 say ur(j) pict "999999.99"
@ str,27 say ro(j) pict "99999.999"
@ str,36 say  t(j) pict "9999999"
