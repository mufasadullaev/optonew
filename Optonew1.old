procedure FLAG2
st=2
set color to R
do while st<23
@ st,2,st,77 box "█"
st=st+1
enddo
set color to GR+
@ 2,25 say "█"
@ 3,26 say "█"
@ 4,25 say "█"
@ 5,24 say "██"
@ 6,23 say "██"
@ 7,22 say "██"
@ 8,18 say "█████"
