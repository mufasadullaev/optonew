procedure PERERAS
clear
@ 10,20 say "ИДЕТ ОБРАБОТКА ИНФОРМАЦИИ"
@ 12,28 say "ЖДИТЕ..."
dimension ni(7,13),ti(7,13),dt(13)
select 1
go top
n=gg*10000+mm*100+dd
set filter to nome=n
go top
i=1
do while i<8
ni(i,1)=blok1
ni(i,2)=blok2
ni(i,3)=blok3
ni(i,4)=blok4
ni(i,5)=blok5
ni(i,6)=blok6
ni(i,7)=blok7
ni(i,8)=blok8
ni(i,9)=blok9
ni(i,10)=blok10
ni(i,11)=blok11
ni(i,12)=blok12
ni(i,13)=sblok
skip
i=i+1
enddo
i=1
do while i<8
ti(i,1)=blok1
ti(i,2)=blok2
ti(i,3)=blok3
ti(i,4)=blok4
ti(i,5)=blok5
ti(i,6)=blok6
ti(i,7)=blok7
ti(i,8)=blok8
ti(i,9)=blok9
ti(i,10)=blok10
ti(i,11)=blok11
ti(i,12)=blok12
ti(i,13)=sblok
skip
i=i+1
enddo
dt(1)=blok1
dt(2)=blok2
dt(3)=blok3
dt(4)=blok4
dt(5)=blok5
dt(6)=blok6
dt(7)=blok7
dt(8)=blok8
dt(9)=blok9
dt(10)=blok10
dt(11)=blok11
dt(12)=blok12
dt(13)=sblok
skip
ei=sblok
n=gg*10000+mm*100+dd
set filter to
select 2
seek n
if ! found()
append blank
repl nomer with n
endif
a1=10.6*ni(1,1)*ti(1,1)
a2=10.6*ni(1,2)*ti(1,2)
a3=10.6*ni(1,3)*ti(1,3)
a4=10.6*ni(1,4)*ti(1,4)
