proc WYR4SEL
* данные для селектора и акта из программы WYRABOTKA
* 07.11.2000


*@ 10,20 say "ЗАПОМНИТЬ ДАННЫЕ ДЛЯ СЕЛЕКТОРА ?"
*otz=1
*@ 11,26 say " НЕТ    ДА ?"
*@ 11,26 prompt " НЕТ "
*@ 11,33 prompt " ДА "
*menu to otz
*if otz=0 .or. otz=1
*   restore screen from ww
*   use
*   close all
*   return
*endif
*@ 12,20 say "ВЫ СДЕЛАЛИ `SEMES` ДЛЯ СЕЛЕКТОРА ?"
*otz=2
*@ 13,26 say " НЕТ    ДА ?"
*@ 13,26 prompt "НЕТ "
*@ 13,33 prompt " ДА "
*menu to otz
*if otz = 2

set console on
*wait 'wyrsel'
   select 3
   use wyrab3
   select 4
   use wyrab4.dbf
   go top
   dele all
   pack
   select 1
   use wyrab1 index wyrab1 
   go top
   select 2
   use wyrab2 index wyrab2
   i=1
   do while i<13
      select 1
      sum1=timk+tim
      sum2=pkw
      sum3=pks
*      sum3=round(sum3,0)
      skip
      select 4
      go bott
      append blank
      repl ego1 with sum1
      repl ego2 with sum2
      repl ego3 with sum3
      do HRAN
      i=i+12
      do HRAN
      i=i-12
      i=i+1
   enddo
   i=0
   j=188          && трансформаторы
   select 4
   go top
   select 1
   go top
   do while i<4
      sum1=trks
      select 4
      repl ego4 with sum1
      i=i+j
      do HRAN
      select 4
      i=i-j
      skip
      select 1
      skip
      i=i+1
   enddo
*endif
restore screen from ww
close all
use
*wait 'wyrsel quit'
return
            ␀
