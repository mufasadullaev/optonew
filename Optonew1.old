ttt=0
now0=0
now1=0
now2=0
now3=0
now4=0
now5=0
cel1=0
xx1=0
xx2=0
xx3=0
dime liz(15)
zam=1
idd=1
imm=1
igg=1995
* замена начальных по мех-м
