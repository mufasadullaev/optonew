procedure SHAK1
@ str,45 say "УТВЕРЖДАЮ"
str=str+1
@ str,35 say "ГЛАВНЫЙ  ИНЖЕНЕР  ТОШДИЭС"
str=str+1
@ str,35 say "__________ М.Х. САМАТОВ"
str=str+1
@ str,35 say "________________       г."
str=str+2
@ str,30 say "А К Т "
str=str+2
@ str,0 say "г. ТАШКЕНТ           N _____  от                     г."
@ str,33 say idd pict "99"
@ str,36 say me(imm) pict ""
@ str,44 say "Я"
@ str,48 say igg pict "9999"
str=str+1
@ str,18 say "Мы, нижеподписавшиеся :"
str=str+1
@ str,18 say "О.Г. ЕРЦЕНКИН - начальник ПТО,"
str=str+1
@ str,18 say "О.С. ХАШИМОВ  - начальник эл. цеха,"
str=str+1
@ str,18 say "составили настоящий акт о том,что в            с.г."
if imm=1
   irr=12
     else
       irr=imm-1
endif
@ str,54 say me(irr) pict ""
@ str,62 say "Е"
str=str+3
@ str,20 say "1. ВЫРАБОТАНО ЭЛЕКТРОЭНЕРГИИ"
do SHAK11
return
procedure SHAK2
@ str,0 say "ИВЦ ТОШДИЭС"
str=str+3
