endif
enddo
return
* замена по межсис. перет.
procedure ZAMS
clear
@ 1,15 say "ЗАМЕHА СЧЕТЧИКОВ ПО МЕЖСИСТЕМHЫМ ПЕРЕТОКАМ"
@ 5,0 say  "╔══════════╦══════════╦══════════╦══════════╦═══════════╦═════════════╗"
@ 6,0 say  "║СТАРЫЙ СЧ.║ НОВЫЙ СЧ.║ КОЭФ. СЧ.║ Э/Э нач. ║ Э/Э кон.  ║Э/Э мимо квт.║"
@ 7,0 say  "╠══════════╬══════════╬══════════╬══════════╬═══════════╬═════════════╣"
kwd=8
do while kwd<18
   @ kwd,0 say  "║          ║          ║          ║          ║           ║             ║"
   kwd=kwd+1
enddo
@ 18,0 say "╚══════════╩══════════╩══════════╩══════════╩═══════════╩═════════════╝"
kwd=8
*************************
@ 19,4 say 'Если по счетчику замена уже была,то запись по данной замене '
@ 20,4 say 'выдается на экран для корректировки, после корректировки теку-'
@ 21,4 say 'щей строки выдается новая строка для следующей замены '
@ 22,4 say 'Для выхода из пустой строки нажмите <Esc> '  
*************************
do while .t.
   k1=0
   @ 2,0 say "Введите номер заменяемого счетчика (либо ESC - выход)"
   @ 2,57 get k1 pict "99999999"
   read
   @ 4,0 say "                                                          "
   l = readkey()
   if l=12
      return
   endif
   if k1=0
      loop
   endif
   select 2
   go top
   set filter to zak2=k1
   lld=0
   count to lld
   if lld=0
      go top
      set filter to zak4=k1
      lld=0
      count to lld
      if lld=0
         set color to gr+*//b
         @ 4,10 say "СЧЕТЧИК С ТАКИМ НОМЕРОМ НЕ СУЩЕСТВУЕТ."
         set color to w+//b
         loop
      endif
   endif
   set filter to
   select 6
   go top
   set filter to mss1=k1
   lld=0
   count to lld
   if lld=0
      append blank
      repl mss1 with k1
      repl mss2 with 0
      repl mss3 with 0
      repl mss4 with 0
      repl mss5 with 0
      repl mss6 with 0
         else
            go top
******* 29.05.2000    для ввода замены счетч. в течении месяца более 1-го раза
 Do while .not. eof()
   @ kwd,2 get mss1 pict "99999999"
   @ kwd,12 get mss2 pict "99999999"
   @ kwd,24 get mss3 pict "99999999"
   @ kwd,35 get mss4 pict "99999999"
   @ kwd,46 get mss5 pict "99999999"
   @ kwd,57 get mss6 pict "99999999"
    read
   if mss2=0.and.mss3=0.and.mss4=0.and.mss5=0.and.mss6=0
      dele
      pack
   endif
    kwd=kwd+1
   skip
 Enddo
      append blank
      repl mss1 with k1
      repl mss2 with 0
      repl mss3 with 0
      repl mss4 with 0
      repl mss5 with 0
      repl mss6 with 0
*******
   endif
*    kwd=kwd+1

   @ kwd,2 say mss1 pict "99999999"
   @ kwd,12 get mss2 pict "99999999"
   @ kwd,24 get mss3 pict "99999999"
   @ kwd,35 get mss4 pict "99999999"
   @ kwd,46 get mss5 pict "99999999"
   @ kwd,57 get mss6 pict "99999999"
   read
   if mss2=0.and.mss3=0.and.mss4=0.and.mss5=0.and.mss6=0
      dele
      pack
   endif
   skip
   kwd=kwd+1
   set filter to
   select 2
enddo
return    
* расчет и печать по межсис. перетокам
procedure MSIS
str=str+1
@ str,0 say "потре- !----------------------------------------------------------"
str=str+1
@ str,0 say "битель !    N   !   K   !        !        !          ! Э/Энергия !"
str=str+1
@ str,0 say "       ! счетч. ! счетч.!    П   !   ПК   ! РАЗНОСТЬ ! (тыс.квт) !"
str=str+1
@ str,0 say "------------------------------------------------------------------"
str=str+1
select 2
go top
sum1=0
sum2=0
i=1
do while i<6
   select 2
   do case
      case i=1
         @ str,0 say "Л-2-Ч"
      case i=2
         @ str,0 say "Л-2-Д"
      case i=3
         @ str,0 say "Л-501"
      case i=4
         @ str,0 say "Л-522"
      case i=5
         @ str,0 say "ОВ-220"
   endcase
   if j=1
      sum2=zak2
      w1=zak22-zak21
      sin1=zak3*w1/1000
      else
         sum2=zak4
         w1=zak42-zak41
         sin1=zak5*w1/1000
   endif
         sum1=sum1+sin1
   if j=1
      @ str,9 say zak2 pict "99999999"
      @ str,17 say zak3 pict "9999999"
      @ str,25 say zak21 pict "99999999"
      @ str,34 say zak22 pict "99999999"
      else
         @ str,9 say zak4 pict "99999999"
         @ str,17 say zak5 pict "9999999"
         @ str,25 say zak41 pict "99999999"
         @ str,34 say zak42 pict "99999999"
   endif
   @ str,45 say w1 pict "99999999"
   @ str,56 say sin1 pict "99999999"
   i=i+1
   skip
   str=str+1
select 6
go top
set filter to mss1=sum2
lld=0
count to lld
if lld>0
   go top
******* 29.05.2000    для замены счетч. в течении месяца более 1-го раза
    Do while .not. eof()
*******
   w1=mss5-mss4
   sin1=(mss3*w1+mss6)/1000
   sum1=sum1+sin1
   @ str,8 say "*"
   @ str,9 say mss2 pict "99999999"
   @ str,17 say mss3 pict "9999999"
   @ str,25 say mss4 pict "99999999"
   @ str,34 say mss5 pict "99999999"
   @ str,45 say w1 pict "99999999"
   @ str,56 say sin1 pict "99999999"
   str=str+1
******* 29.05.2000    для замены счетч. в течении месяца более 1-го раза
      skip
    Enddo
*******
endif
set filter to
enddo
str=str+1
*@ str,0 say "И Т О Г О"
*@ str,56 say sum1 pict "999999999"
str=str+4
if j=2
   @ str,22 say "НАЧАЛЬHИК ПТО"
   @ str,52 say " О.Г. ЕРЦЕНКИН"
   str=str+2
   @ str,22 say "НАЧАЛЬHИК ЭЛЦЕХА"
   @ str,52 say " О.С. ХАШИМОВ"
   str=str+1
   @ str,0 say ""
   str=str+1
   @ str,0 say ""
   str=str+1
   @ str,0 say ""
   str=str+1
   @ str,0 say ""
   str=str+1
   @ str,0 say ""
   str=str+1
   @ str,0 say ""
endif
return
* печать по режиму синх.комп.
procedure SINXK
str=str+2
@ str,7 say "РАБОТА В РЕЖИМЕ СИНХРОННОГО КОМПЕНСАТОРА"
i=1
sum2=0
do SHAK11
do while .t.
   if num(i)=0
      exit()
   endif
   select 2
   go top
   skip i+12
   ks2=zak1
   select 1
   go top
   ks1=num(i)
   skip ks1+12
   ks1=ks
   w1=nk(i)-nn(i)
   sin1=(ks1*w1+nen(i))
   sum2=sum2+sin1
   @ str,1 say num(i) pict "999"
   @ str,6 say ks2 pict "99999999"
   @ str,15 say ks1 pict "99999"
   @ str,22 say nn(i) pict "9999999"
   @ str,31 say nk(i) pict "9999999"
   @ str,39 say w1 pict "99999999"
   @ str,49 say sin1 pict "999999999"
   i=i+1
   str=str+1
enddo
sum1=sum1-sum2
@ str,0 say "--------------------------------------------------------------"
str=str+1
@ str,0 say "ВСЕГО ПО СИНХРОННЫМ КОМПЕНСАТОРАМ"
@ str,49 say sum2 pict "999999999"
str=str+5
return

procedure AKTNS
* замена счетчиков для расчета акта
sk1=0
w1=0
w2=0
*save screen to ww
*use
*close all
clear
@ 9,15 say " 3. AKTNS  "
@ 10,15 say "ЗАМЕНА ЗАВОДСКИХ НОМЕРОВ СЧЕТЧИКОВ МЕЖСИСТЕМНЫХ "
@ 12,15 say "   ПЕРЕТОКОВ ДЛЯ РАСЧЕТОВ АКТОВ ПО ВЫРАБОТКЕ"
wait "Нажмите любую клавишу ..."
*otz=1                     &&   10.10.2002
*@ 14,26 prompt " ДА"      &&
*@ 14,37 prompt "НЕТ"      &&
*menu to otz               &&
*if otz=2.or.otz=0         &&
*  return
*endif
select 1
use akt1.dbf
select 2
use akt2.dbf
if file('akt2.idx')
   delete file akt2.idx
endif
index on mss1 to akt2
go top

Do while ! eof()
   select 2     && Akt2
*?wait "1"
   ks1=mss1
********************* 
  Do while ks1=mss1    && если было несколько замен по счетчику  29.05.2000
*?wait "2"
   w1=mss2             && последней заменой считается последняя запись по
   w2=mss3             && порядку
   skip 
   if eof()
      exit
   endif
   if ks1#mss1
      skip -1            && чтобы не пропустить запись
      exit
   endif
  Enddo
*********************
   select 1    && Akt1
   go top
   set filter to zak2=ks1
   lld=0
   count to lld
   if lld=0
      go top
      set filter to zak4=ks1
      lld=0
      count to lld
      if lld=0
         clear
         @ 10,20 say "ОШИБКА В ДАННЫХ ПО СЧЕТЧИКАМ"
         @ 11,20 say "   МЕЖСИСТЕМНЫХ ПЕРЕТОКОВ"
         @ 12,20 say ks1 pict "99999999"
         @ 13,20 say " нажмите любую клавишу..."
         read
         close all
         return
         else
            i=2
      endif
      else
         i=1
   endif
   go top
   if i=1
      repl zak2 with w1      && по выработке  29.05.2000
      repl zak3 with w2
         else
      repl zak4 with w1      && по межсист.перетокам   29.05.2000
      repl zak5 with w2
   endif

select 2     && Akt2
  if eof()
     exit
  endif
    skip
Enddo
 select 2
 use akt2.dbf
 go top
 dele all
 pack
return

procedure AKTKOR
sele 1
use wyrab2 index wyrab2
clear
@ 1,15 say "КОРРЕКТИРОВКА ДАННЫХ ПО СОБСТВЕННЫМ НУЖДАМ."
@ 2,15 say  "╔════════════════════════════════════╗"
@ 3,15 say  "║        СОБСТВЕННЫЕ  НУЖДЫ          ║"
@ 4,15 say  "╠═════════╦════════════╦═════════════╣"
@ 5,15 say  "║N счетч. ║   Э/Э нач. ║   Э/Э кон.  ║"
@ 6,15 say  "╠═════════╬════════════╬═════════════╣"
kol=7
do while kol<19
   @ kol,15 say  "║         ║            ║             ║"
   kol=kol+1
enddo
@ 19,15 say "╚═════════╩════════════╩═════════════╝"
kol=7
mini=1
maxi=12
i=1
go top
skip 12
do while i<13
   @ kol,17 say noms pict "999"
   @ kol,27 say mim pict "9999999.99"
   @ kol,40 say mik pict "9999999.99"
   i=i+1
   skip
   kol=kol+1
enddo
kol=7
i=1
go top
skip 12
do while .t.
   @ kol,17 say noms pict "999"
   @ kol,27 get mim pict "9999999.99"
   @ kol,40 get mik pict "9999999.99"
read
l = readkey()
   @ kol,17 say noms pict "999"
   @ kol,27 say mim pict "9999999.99"
   @ kol,40 say mik pict "9999999.99"
if l = 12       &&  esc
 exit
endif
if l=5.or.l=270.or.l=15    && ус.end,enter,стрелка вн.
   if i = maxi
      loop
   endif
   kol=kol+1
   i=i+1
   skip
   loop
endif
if l = 4                      &&    стрелка вв.
   if i = mini
      loop
   endif
   i=i-1
   kol=kol-1
   skip -1
endif
enddo
return

procedure WYRABOTKA
dimension liz(16),tr(4)
ddd=0
prom=0.0
ss1=0.0
ss2=0.0
w1=0.0
w2=0.0
w3=0.0
w4=0.0
ks0=0.0
ks1=0.0
ks2=0.0
ks3=0.0
sw=0.0
ssn=0.0
sti=0.0
bb1=0.0
bb2=0.0
bb3=0.0
bb4=0.0
bb5=0.0
kk1=0.0
kk2=0.0
kk3=0.0
kk4=0.0
kk5=0.0
