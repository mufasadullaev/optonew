procedure COPDATA
@ 18,40,20,50 box win1+ " "
@ 19,42 prompt " A "
@ 19,46 prompt " B "
menu to p2
if p2=0
return
endif
set color to gr+*//b
@ 24,17 say "Установите дискету. Нажмите любую клавишу..."
set color to w+//b
l=inkey(0)
if l=27
return
endif
do case
case p2=1
*! copy akt*.dbf a:
*! copy grp*.dbf a:
*! copy grp*.idx a:
*! copy wyr*.dbf a:
*! copy wyr*.idx a:
*! copy sel*.dbf a:
*! copy sel*.idx a:
*! copy maz*.dbf a:
*! copy maz*.idx a:
*! copy baxta*.dbf a:
*! copy baxta*.idx a:
*! copy pere*.* a:
! copy *.dbf a:
*! copy *.idx a:
case p2=2
*! copy akt*.dbf b:
*! copy grp*.dbf b:
*! copy grp*.idx b:
*! copy wyr*.dbf b:
*! copy wyr*.idx b:
*! copy sel*.dbf b:
*! copy sel*.idx b:
*! copy baxta*.dbf b:
*! copy baxta*.idx b:
*! copy maz*.dbf b:
*! copy maz*.idx b:
*! copy pere*.* b:
! copy *.dbf b:
*! copy *.idx b:
endcase
return
procedure HELP
save screen to ww
clear
@ 0,0,22,79 box +" "
@ 1,1 say "F1+n - последовательное нажатие клавиш F1, какого-либо номера и Enter - уста-"
@ 2,1 say "       вливает указатель на экране на запись с этим номером."
@ 3,1 say "ст   - стрелка вниз  - перемещение указателя на экране на поле (строку) вниз."
@ 4,1 say "ре   - стрелка вверх - перемещение указателя на экране на строку вверх."
@ 5,1 say "л    - стрелка вправо - перемещение курсора в поле на позицию вправо."
@ 6,1 say "ки   - стрелка влево  - перемещение курсора в поле на позицию влево."
@ 7,1 say "ESC  - нажатие ESC - прекращение выполнения операции, ввода, работы программы."
@ 8,1 say "PgUp - нажатие клавиши PgUp - просмотр предыдущего экрана."
@ 9,1 say "PgDn - нажатие клавиши PgDn - просмотр следующего экрана."
@ 10,1 say"Enter- нажатие клавиши Enter - завершение ввода данных в поле."
@ 11,1 say"^End - нажатие Ctrl+End - включение режима добавления записи."
@ 12,1 say"^PgUp- нажатие Ctrl+PgUp - установка указателя на первую запись."
@ 13,1 say"^PgDn- нажатие Ctrl+PgDn - установка указателя на последнюю запись."
@ 14,1 say"Home - нажатие клавиши Home - установка курсора в начало поля ввода данных."
@ 15,1 say"End  - нажатие клавиши End  - установка курсора в конец  поля ввода данных."
@ 16,1 say"Ins  - нажатие клавиши Ins  - включение режима вставки символов в поле ввода."
@ 17,1 say"Del  - нажатие клавиши Del  - удаление одного символа справа от курсора."
@ 18,1 say"^Home- нажатие Ctrl+Home - удаление текущей записи. Указатель устанавливается"
@ 19,1 say"       на пследующую запись."
@ 20,1 say"^Y   - нажатие Ctrl+Y - удаление символов поля ввода от курсора до конца поля."
@ 21,1 say"Bcks - нажатие BackSpace - удаление одного символа слева от курсора."
@ 23,0 say re pict ""
@ 24,0 say te pict ""
l=inkey(0)
restore screen from ww
return
procedure STARRING
starr=0
set console on
set color to r/w
*@ 21,13 say "                                                     "
i=1
k=0
do while .t.
k=k+1
if k=71
k=1
endif
do case
case k>0.and.k<11
*set color to BG+
case k>10.and.k<21
*set color to R+
case k>20.and.k<31
*set color to GR+
case k>30.and.k<41
*set color to G+
case k>40.and.k<51
*set color to B+
case k>50.and.k<61
*set color to W+
case k>60.and.k<71
*set color to RB+
endcase
if starr=200
exit
endif
*@ 21,14 say star(i) pict ""
set color to X
*@ 21,13 say " "
*@ 21,65 say " "
i=i+1
if i>51
i=1
endif
j=1

do while j<370
j=j+1
l=inkey()
if l # 0
exit
endif
enddo

if l # 0
exit
endif
starr=starr+1
enddo
return
