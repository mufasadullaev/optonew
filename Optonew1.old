return
procedure SHAK11
str=str+1
@ str,0 say "------------------------------------------------------------------"
str=str+1
@ str,0 say "  NN  !   N   !  K  !         !          !            !  Э/Энергия!"
str=str+1
@ str,0 say "блоков! счетч !счетч!     П   !    ПК    !   РАЗНОСТЬ !    (квт)  !"
str=str+1
@ str,0 say "------------------------------------------------------------------"
str=str+1
return
* печать выраб. сн. транс.
procedure PEAK1
ii=0
if i>12
   ii=i-12
      else
         ii=i
endif
   do case
      case i=188
   @ str,0 say "ТС-20"
      case i=189
   @ str,0 say "ТС-30"
      case i=190
   @ str,0 say "3ТР-А"
      case i=191
   @ str,0 say "3ТР-Б"
      case i<187
   @ str,2 say ii pict "999"
   endcase
@ str,8 say k2 pict "999999"
@ str,13 say k1 pict "999999"
@ str,20 say w1 pict "9999999.99"
@ str,31 say w2 pict "9999999.99"
@ str,44 say sin1 pict "9999999.99"
@ str,57 say sin2 pict "999999999"
str=str+1
return
* ввод по межсист. перетокам
*прием
procedure VVSIS
clear
@ 1,15 say "ВВОД ДАННЫХ ПО МЕЖСИСТЕМНЫМ ПЕРЕТОКАМ."
@ 2,15 say  "╔════════════════════════════════╗"
@ 3,15 say  "║          П Р И Е М             ║"
@ 4,15 say  "╠══════════╦══════════╦══════════╣"
@ 5,15 say  "║ N счетч. ║ Э/Э нач. ║ Э/Э кон. ║"
@ 6,15 say  "╠══════════╬══════════╬══════════╣"
kol=7
do while kol<13
   @ kol,15 say  "║          ║          ║          ║"
   kol=kol+1
enddo
@ 13,15 say  "╠══════════╩══════════╩══════════╣"
@ 14,15 say  "║          О Т Д А Ч А           ║"
@ 15,15 say  "╠══════════╦══════════╦══════════╣"
kol=16
do while kol<22
   @ kol,15 say  "║          ║          ║          ║"
   kol=kol+1
enddo
@ 22,15 say "╚══════════╩══════════╩══════════╝"
kol=7
mini=1
maxi=5
i=1
select 2
use akt1.dbf
go top
do while i<6
   @ kol,17 say zak2 pict "99999999"
   @ kol,28 say zak21 pict "99999999"
   @ kol,39 say zak22 pict "99999999"
   i=i+1
   skip
   kol=kol+1
enddo
go top
kol=16
i=1
do while i<6
   @ kol,17 say zak4 pict "99999999"
   @ kol,28 say zak41 pict "99999999"
   @ kol,39 say zak42 pict "99999999"
   i=i+1
   skip
   kol=kol+1
enddo
kol=7
i=1
go top
do while .t.
   @ kol,17 say zak2 pict "99999999"
   @ kol,28 get zak21 pict "99999999"
   @ kol,39 get zak22 pict "99999999"
read
l = readkey()
   @ kol,17 say zak2 pict "99999999"
   @ kol,28 say zak21 pict "99999999"
   @ kol,39 say zak22 pict "99999999"
if l = 12       &&  esc
 exit
endif
if l=5.or.l=270.or.l=15    && ус.end,enter,стрелка вн.
   if i = maxi
      loop
   endif
   kol=kol+1
   i=i+1
   skip
   loop
endif
if l = 4                      &&    стрелка вв.
   if i = mini
      loop
   endif
   i=i-1
   kol=kol-1
   skip -1
endif
enddo
return
* передача
procedure VVSIS1
mini=1
maxi=5
kol=16
go top
i=1
do while .t.
   @ kol,17 say zak4 pict "99999999"
   @ kol,28 get zak41 pict "99999999"
   @ kol,39 get zak42 pict "99999999"
read
l = readkey()
   @ kol,17 say zak4 pict "99999999"
   @ kol,28 say zak41 pict "99999999"
   @ kol,39 say zak42 pict "99999999"
if l = 12       &&  esc
 exit
endif
if l=5.or.l=270.or.l=15    && ус.end,enter,стрелка вн.
   if i = maxi
      loop
   endif
   kol=kol+1
